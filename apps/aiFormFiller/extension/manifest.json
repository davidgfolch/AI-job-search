{
  "manifest_version": 3,
  "name": "AI Form Filler",
  "version": "0.1.0",
  "description": "Answer job application form questions using your CV and AI",
  "permissions": [
    "contextMenus",
    "sidePanel",
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "http://127.0.0.1:8080/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "side_panel": {
    "default_path": "sidepanel/panel.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
