# =============================================================================
# Docker / System
# =============================================================================
# OLLAMA_MODELS_PATH=C:/Users/YOUR_USERNAME/.ollama  # Windows path to Ollama models (optional, defaults to ~/.ollama)
GLOBAL_TZ=Europe/Madrid

# =============================================================================
# Database (commonlib)
# =============================================================================
COMMONLIB_DB_NAME=jobs
# MySQL host. Supports:
#   - Single IP:           192.168.0.10
#   - CIDR range:          192.168.1.0/24
#   - IP range:            192.168.0.10-192.168.0.250 or 192.168.0.10-250
#   - Comma-separated:     192.168.0.10,192.168.0.11
# If unset or empty, defaults to 127.0.0.1.
# If all configured hosts fail, commonlib auto-scans the LAN for a MySQL server.
#COMMONLIB_DB_HOST=192.168.0.10/99,192.168.0.100/250
#COMMONLIB_DB_HOST=192.168.0.10/250
#COMMONLIB_DB_HOST=192.168.0.10/250

# =============================================================================
# Backend API
# =============================================================================
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# =============================================================================
# Scrapper
# =============================================================================
SCRAPPER_RUN_IN_TABS=False
SCRAPPER_USE_UNDETECTED_CHROMEDRIVER=True
SCRAPPER_JOBS_SEARCH=java,python,scala,clojure,senior software engineer

# Scrapper - LinkedIn
SCRAPPER_LINKEDIN_RUN_CADENCY=2h
SCRAPPER_LINKEDIN_RUN_CADENCY_7-19=30m
SCRAPPER_LINKEDIN_AUTORUN=True
SCRAPPER_LINKEDIN_DEBUG=False

# Scrapper - InfoJobs
SCRAPPER_INFOJOBS_RUN_CADENCY=2h
# SCRAPPER_INFOJOBS_RUN_CADENCY_7-19=1h 30m
SCRAPPER_INFOJOBS_AUTORUN=True
SCRAPPER_INFOJOBS_DEBUG=False

# Scrapper - Glassdoor
SCRAPPER_GLASSDOOR_RUN_CADENCY=3h
SCRAPPER_GLASSDOOR_RUN_CADENCY_7-19=2h
SCRAPPER_GLASSDOOR_AUTORUN=True
SCRAPPER_GLASSDOOR_DEBUG=False
SCRAPPER_GLASSDOOR_JOBS_SEARCH=espa%C3%B1a-java-empleos-SRCH_IL.0,6_IN219_KO7,11.htm|~|espa%C3%B1a-python-empleos-SRCH_IL.0,6_IN219_KO7,13.htm|~|espa%C3%B1a-scala-empleos-SRCH_IL.0,6_IN219_KO7,12.htm|~|espa%C3%B1a-clojure-empleos-SRCH_IL.0,6_IN219_KO7,14.htm|~|espa%C3%B1a-senior-software-engineer-empleos-SRCH_IL.0,6_IN219_KO7,31.htm
SCRAPPER_GLASSDOOR_JOBS_SEARCH_BASE_URL=https://www.glassdoor.es/Empleo/{search}?remoteWorkType=1&fromAge=1&sortBy=date_desc

# Scrapper - TecnoEmpleo
SCRAPPER_TECNOEMPLEO_RUN_CADENCY=3h
SCRAPPER_TECNOEMPLEO_RUN_CADENCY_7-19=1h 30m
SCRAPPER_TECNOEMPLEO_AUTORUN=True
SCRAPPER_TECNOEMPLEO_DEBUG=False

# Scrapper - Indeed
SCRAPPER_INDEED_RUN_CADENCY=3h
SCRAPPER_INDEED_AUTORUN=True
SCRAPPER_INDEED_DEBUG=False
# Scrapper (SCRAPLING VERSION) - Indeed
SCRAPPER_INDEED_SCRAPLING=True
SCRAPPER_INDEED_PROXIES=

# LLM Scraping Configuration (LinkedIn hybrid approach)
LINKEDIN_USE_LLM=False
LLM_PROVIDER=zhipu # Options: zhipu, ollama, huggingface
LLM_MODEL=glm-4-flash # Zhipu: glm-4-flash | Ollama: qwen2.5-coder:7b | HF: Qwen/Qwen2.5-72B-Instruct

# =============================================================================
# aiEnrich (CrewAI + Ollama)
# =============================================================================
AI_ENRICH_JOB='true'
AI_ENRICH_SKILL='false'
AI_ENRICH_TIMEOUT_JOB='90'
AI_ENRICH_OLLAMA_BASE_URL='http://localhost:11434'
AI_ENRICH_OLLAMA_MODEL='ollama/qwen2.5:3b'   # Recommended: qwen2.5:3b (fast+good), phi3.5:3b (very fast+moderate), llama3.2:1b (fastest+lower)
AI_ENRICH_SKILL_CATEGORIES='Programming Language,Framework,Library,Tool,Database,Cloud Platform,Operating System,Methodology,Other'

# =============================================================================
# aiEnrichNew (HuggingFace Transformers)
# =============================================================================
AI_ENRICHNEW_JOB='False'
AI_ENRICHNEW_SKILL='True'
AI_ENRICHNEW_TIMEOUT_JOB='90'
AI_ENRICHNEW_TIMEOUT_SKILL='90'
AI_ENRICHNEW_MODEL_ID='Qwen/Qwen2.5-1.5B-Instruct'
AI_ENRICHNEW_MAX_NEW_TOKENS='2048'
AI_ENRICHNEW_TEMPERATURE='0.1'
AI_ENRICHNEW_TOP_P='0.9'
AI_ENRICHNEW_REPETITION_PENALTY='1.1'
AI_ENRICHNEW_BATCH_SIZE='10'
AI_ENRICHNEW_INPUT_MAX_LEN='12000'
AI_ENRICHNEW_GPU_CLEANUP='True'
AI_ENRICHNEW_SKILL_CATEGORIES='Programming Language,Framework,Library,Tool,Database,Cloud Platform,Operating System,Methodology,Other'
AI_ENRICHNEW_SKILL_ENRICH_LIMIT='10'

# =============================================================================
# aiEnrich3 (GLiNER + mDeBERTa)
# =============================================================================
AI_ENRICH3_JOB='False'
AI_ENRICH3_SKILL='False'
AI_ENRICH3_INPUT_MAX_LEN='10000'
AI_ENRICH3_MAX_CONCURRENCY='4'

# =============================================================================
# Observability (shared across aiEnrich, aiEnrichNew, aiEnrich3)
# =============================================================================
# AI_ENRICH_LOG_DIR=data/logs                # Directory for JSONL log files
# AI_ENRICH_LOG_LEVEL=20                     # 10=DEBUG, 20=INFO, 30=WARNING, 40=ERROR
# AI_ENRICH_LOG_COLOR=True                   # Colored console output (vs raw JSON)
# AI_ENRICH_LOG_FILE_MAX_BYTES=10485760      # Max bytes per JSONL file before rotation (default 10MB)
# AI_ENRICH_LOG_FILE_BACKUP_COUNT=5          # Number of rotated log files to keep
# AI_ENRICH_METRICS_FILE=data/metrics/enrichment_metrics.json  # Metrics persistence path

# =============================================================================
# Prometheus & Grafana (Observability)
# =============================================================================
# PROMETHEUS_PORT=9090                # Prometheus web UI port
# GRAFANA_PORT=3000                   # Grafana web UI port
# GRAFANA_ADMIN_USER=admin            # Grafana admin username
# GRAFANA_ADMIN_PASSWORD=admin        # Grafana admin password

# =============================================================================
# aiCvMatcher (SentenceTransformers)
# =============================================================================
AI_CVMATCHER_ENABLED='true'
AI_CVMATCHER_LIMIT='100'

# =============================================================================
# aiFormFiller (AI-powered job application form answerer)
# =============================================================================
AI_FORM_PROVIDER=local
AI_FORM_PORT=8080
# AI_FORM_HF_MODEL=Qwen/Qwen2.5-1.5B-Instruct
# OPENAI_MODEL=gpt-4o-mini
# OPENROUTER_MODEL=openai/gpt-4o-mini
# AI_FORM_TIMEOUT=30
# AI_FORM_TEMPERATURE=0.1
# AI_FORM_MAX_TOKENS=512
# AI_FORM_CV_PATH=cv/cv.txt
# AI_FORM_LOOKING_FOR_PATH=cv/looking-for.txt

# =============================================================================
# MongoDB (Salary History & future concerns)
# =============================================================================
MONGO_URI=mongodb://${MONGO_USERNAME}:${MONGO_PASSWORD}@localhost:27017/
MONGO_DATABASE=jobs
# CQRS: separate read/write URIs for replica set setups (optional, defaults to MONGO_URI)
# MONGO_READ_URI=mongodb://readuser:pass@secondary:27017/
# MONGO_WRITE_URI=mongodb://writeuser:pass@primary:27017/

# =============================================================================
# Cron (Background Jobs)
# =============================================================================
CRON_SALARY_CADENCY=1h

# =============================================================================
# Settings (UI)
# =============================================================================
UI_APPLY_MODAL_DEFAULT_TEXT='- applied by 45k'
UI_GROSS_YEAR_URL='https://tecalculo.com/calculadora-de-sueldo-neto'
